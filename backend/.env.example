# Copy this file to .env and fill in real values. Never commit .env to git.

# --- LLM (required for analysis) ---
# Free Groq API key from https://console.groq.com
GROQ_API_KEY=gsk_xxx

# --- Stripe (required for paid web dashboard tiers) ---
STRIPE_SECRET_KEY=sk_test_from_stripe_dashboard

# Create 4 products in Stripe (Quick $5, Standard $10, Pro $25, Pro Max $50),
# then paste their Price IDs here:
STRIPE_PRICE_QUICK=price_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PROMAX=price_xxx

# --- CORS (optional; comma-separated origins for production frontend) ---
# Leave unset for local dev (allows all origins). On Render, set to your Static Site URL:
# ALLOWED_ORIGINS=https://verdict-frontend.onrender.com,http://localhost:5173

# --- CROO / CAP agent commerce (optional; enables on-chain agent orders) ---
# Required only if you want the CAP listener in main.py to start.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://ws.croo.network
CROO_SDK_KEY=your_croo_sdk_key
